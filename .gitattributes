# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.dart text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# Documentation
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.ttf binary
*.otf binary
*.keystore binary
*.jks binary